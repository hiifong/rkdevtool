{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rkdevtool",
  "version": "0.3.0",
  "identifier": "style.f.rkdevtool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RKDevTool",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "appimage", "deb", "nsis"],
    "resources": [
      "bin/mac/*",
      "bin/linux_x86-64/*",
      "bin/windows_x86-64/*"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/lib/udev/rules.d/99-rkdevtool-rockchip.rules": "../packaging/linux/99-rkdevtool-rockchip.rules"
        },
        "postInstallScript": "../packaging/linux/deb-postinstall.sh",
        "postRemoveScript": "../packaging/linux/deb-postremove.sh"
      }
    }
  }
}
