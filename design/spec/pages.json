{
  "app": {
    "name": "RKDevTool",
    "subtitle": "瑞芯微开发工具",
    "version": "v1.0.0",
    "layout": {
      "type": "sidebar-main",
      "structure": ["sidebar", "main-area", "status-bar"],
      "mainArea": ["page-header", "content-split"],
      "contentSplit": ["left-panel", "log-panel"]
    }
  },
  "navigation": [
    { "id": "download", "label": "下载镜像", "icon": "download", "route": "/download" },
    { "id": "upgrade", "label": "升级固件", "icon": "upgrade", "route": "/upgrade" },
    { "id": "advanced", "label": "高级功能", "icon": "settings", "route": "/advanced" }
  ],
  "pages": {
    "download": {
      "title": "下载镜像",
      "description": "配置分区镜像并按地址烧录到设备",
      "components": {
        "partitionTable": {
          "type": "data-table",
          "width": 648,
          "height": 184,
          "clipContent": false,
          "headerHeight": 40,
          "dataRowHeight": 52,
          "cellHeight": 32,
          "rowPadding": { "horizontal": 12, "vertical": 10 },
          "columnGap": 6,
          "columns": [
            { "key": "index", "label": "#", "width": 26, "align": "center" },
            { "key": "enabled", "label": "", "type": "checkbox", "width": 26, "align": "center" },
            { "key": "storage", "label": "存储", "type": "select", "width": 68, "align": "start", "options": ["", "FLASH", "EMMC", "SD", "SPINOR", "SPINAND", "SATA", "PCIE"] },
            { "key": "address", "label": "地址", "type": "hex-input", "width": 88, "align": "start", "placeholder": "0x00000000" },
            { "key": "name", "label": "名字", "type": "text", "width": 56, "align": "start" },
            { "key": "path", "label": "路径", "type": "file-path-with-browse", "width": 324, "align": "start", "browseAlign": "end", "browseWidth": 32, "browseHeight": 28 }
          ],
          "rowSelection": true,
          "selectedRowStyle": "success-border",
          "addRow": { "label": "新增配置项", "icon": "plus", "position": "footer" }
        },
        "toolbar": {
          "loaderVersion": { "label": "Loader Ver", "example": "1.11" },
          "actions": [
            { "id": "force-address", "label": "强制按地址写", "type": "checkbox", "position": "before-execute" },
            { "id": "execute", "label": "执行", "variant": "primary" },
            { "id": "switch", "label": "切换", "variant": "secondary" },
            { "id": "partition-table", "label": "设备分区表", "variant": "secondary" },
            { "id": "clear", "label": "清空", "variant": "secondary" }
          ]
        }
      }
    },
    "upgrade": {
      "title": "升级固件",
      "description": "选择固件包并一键升级设备",
      "components": {
        "firmwareRow": {
          "type": "inline-action-row",
          "items": [
            { "id": "firmware-label", "label": "固件", "type": "label" },
            { "id": "firmware-path", "type": "file-path-input", "flex": "fill" },
            { "id": "firmware-browse", "type": "browse-button", "label": "..." },
            { "id": "upgrade", "label": "升级", "variant": "primary" }
          ]
        },
        "infoFields": [
          { "key": "firmwareVersion", "label": "固件版本", "readonly": true },
          { "key": "loaderVersion", "label": "Loader版本", "readonly": true },
          { "key": "chipInfo", "label": "芯片信息", "readonly": true }
        ]
      }
    },
    "advanced": {
      "title": "高级功能",
      "description": "设备调试、Flash 操作和底层功能",
      "components": {
        "fileInputs": [
          { "key": "boot", "label": "Boot", "browseButton": { "label": "...", "width": 36, "height": 36 }, "action": { "label": "下载", "variant": "primary" } },
          { "key": "firmware", "label": "固件", "browseButton": { "label": "...", "width": 36, "height": 36 }, "action": { "label": "解包", "variant": "secondary" } }
        ],
        "actionGrid": {
          "columns": 4,
          "groups": [
            {
              "name": "信息读取",
              "actions": ["读取FlashID", "读取Flash信息", "读取Chip信息", "读取Capability"]
            },
            {
              "name": "设备控制",
              "actions": ["测试设备", "重启设备", "进入Maskrom", "切换存储"]
            },
            {
              "name": "数据管理",
              "actions": ["清空序列号", "检测安全模式", "导出串口日志", "获取当前存储"]
            },
            {
              "name": "Flash 操作",
              "actions": ["导出镜像", "擦除扇区", "擦除所有", "切换USB3"],
              "destructive": ["擦除扇区", "擦除所有"]
            }
          ]
        },
        "storageList": {
          "type": "selectable-list",
          "items": ["FLASH", "EMMC", "SD", "SD1", "SPINOR", "SPINAND", "RAM", "USB", "SATA", "PCIE"]
        },
        "sectorInputs": [
          { "key": "startSector", "label": "起始扇区", "type": "number" },
          { "key": "sectorCount", "label": "扇区数", "type": "number" }
        ]
      }
    }
  },
  "shared": {
    "logPanel": {
      "title": "输出日志",
      "clearable": true,
      "font": "mono",
      "logLevels": {
        "info": { "color": "#60A5FA" },
        "success": { "color": "#34D399" },
        "error": { "color": "#F87171" },
        "default": { "color": "#E2E8F0" }
      }
    },
    "statusBar": {
      "deviceStates": {
        "connected": { "label": "发现一个 MASKROM 设备", "dotColor": "#10B981" },
        "disconnected": { "label": "没有发现设备", "dotColor": "#EF4444" },
        "loader": { "label": "发现一个 LOADER 设备", "dotColor": "#2563EB" }
      },
      "deviceSelector": { "type": "dropdown", "example": "1-11-3-1-1-3 : MASKROM" }
    }
  }
}
